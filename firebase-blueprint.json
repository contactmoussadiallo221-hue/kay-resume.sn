{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile stored in Firestore to keep track of user and registration date.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth uid." },
        "email": { "type": "string", "description": "The email of the student." },
        "displayName": { "type": "string", "description": "Display name of the student." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Summary": {
      "title": "Summary",
      "description": "A study summary generated from a document or camera captured text.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "difficulty": { "type": "string" },
        "originalText": { "type": "string" },
        "summaryText": { "type": "string" },
        "keyPoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "definitions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": { "type": "string" },
              "definition": { "type": "string" }
            }
          }
        },
        "formulasOrDates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "simplification": { "type": "string" },
        "quiz": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" },
              "explanation": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "subject", "difficulty", "summaryText", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Users collection holding student information."
    },
    "/users/{userId}/summaries/{summaryId}": {
      "schema": "Summary",
      "description": "Subcollection holding summaries generated by an individual student."
    }
  }
}
